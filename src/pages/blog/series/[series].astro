---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Breadcrumbs from "../../../components/astro/Breadcrumbs.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const seriesNames = [...new Set(posts.map((p) => p.data.series).filter(Boolean))] as string[];
  return seriesNames.map((series) => ({
    params: { series },
    props: { series },
  }));
}

const { series } = Astro.props;

const posts = (await getCollection("blog"))
  .filter((p) => p.data.series === series)
  .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
---

<Layout
  title={`${series} Series — Telemetry Drops Blog`}
  description={`All posts in the "${series}" series.`}
  canonical={`/blog/series/${series}/`}
>
  <div class="container-custom py-16">
    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: "Blog", href: "/blog/" },
        { label: `Series: ${series}` },
      ]}
    />

    <h1 class="text-4xl font-bold text-white mt-8 mb-10">{series}</h1>

    <ol class="space-y-4">
      {posts.map((post, index) => (
        <li>
          <a
            href={`/blog/${post.data.slug}/`}
            class="group flex items-start gap-4 rounded-lg border border-white/10 bg-white/[0.02] p-5 hover:border-telemetria-orange/30 transition-colors"
          >
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-sm font-semibold text-white/60 group-hover:text-telemetria-orange group-hover:border-telemetria-orange/30 transition-colors">
              {index + 1}
            </div>
            <div>
              <div class="text-lg font-semibold text-white group-hover:text-telemetria-orange transition-colors">
                {post.data.title}
              </div>
              <p class="text-sm text-white/60 mt-1">{post.data.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </div>
</Layout>
